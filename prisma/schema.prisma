generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int            @id @default(autoincrement())
  number          String?        @unique
  password        String?
  userId          String?        @unique @map("user_id")
  username        String?
  fullName        String?        @map("full_name")
  email           String?        @unique
  address         String?
  dateOfBirth     DateTime?      @map("date_of_birth")
  gender          String?
  refreshToken    String?        @map("refresh_token")
  profileComplete Boolean        @default(false) @map("profile_complete")
  lang            Lang           @default(UZ)
  role            Role           @default(USER)
  status          UserStatus     @default(ACTIVE)

  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  cart            Cart?
  orders          Order[]
  savedProducts   SavedProduct[]

  @@map("users")
}

// Brauzer/TG orqali bir martalik tokenlar (link_, pw_, ro'yxat) — xotira o'rniga DB, server restartda yo'qolmaydi
enum AuthTokenType {
  LINK
  REGISTER
  PASSWORD_SETUP
}

model AuthFlowToken {
  id         Int            @id @default(autoincrement())
  token      String         @unique
  type       AuthTokenType
  userId     Int?           @map("user_id")
  phone      String?
  telegramId String?        @map("telegram_id")
  username   String?
  fullName   String?        @map("full_name")
  expiresAt  DateTime       @map("expires_at")
  consumedAt DateTime?      @map("consumed_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([type])
  @@index([expiresAt])
  @@map("auth_flow_tokens")
}

model Category {
  id           Int                   @id @default(autoincrement())
  name         String                @unique // Default UZ
  isActive     Boolean               @default(true) @map("is_active")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  products     Product[]
  translations CategoryTranslation[]

  @@map("categories")
}

model CategoryTranslation {
  id         Int      @id @default(autoincrement())
  categoryId Int      @map("category_id")
  lang       Lang     // RU yoki EN
  name       String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, lang])
  @@map("category_translations")
}



model Product {
  id           Int                  @id @default(autoincrement())
  productId    String               @unique @map("product_id")
  photos       String[]             @default([])
  category     String
  name         String               // Default UZ
  ingredients  String?              // Default UZ
  uses         String?              // Default UZ
  description  String?              // Default UZ
  price        Float
  amount       Int                  @default(0)
  isActive     Boolean              @default(true) @map("is_active")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  cartItems    CartItem[]
  categoryRel  Category             @relation(fields: [category], references: [name])
  translations ProductTranslation[]
  scores       ProductScore[]
  savedBy      SavedProduct[]

  @@map("products")
}

model ProductTranslation {
  id          Int      @id @default(autoincrement())
  productId   Int      @map("product_id")
  lang        Lang     // RU yoki EN
  name        String
  ingredients String?
  uses        String?
  description String?
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, lang])
  @@map("product_translations")
}


model ProductScore {
  id        Int      @id @default(autoincrement())
  productId String   @map("product_id")
  number    String   // User phone number
  fullName  String   @map("full_name")
  comment   String?
  grade     Int      @default(0) // 0-5
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [productId], onDelete: Cascade)

  @@map("product_scores")
}

model CartItem {
  id           Int     @id @default(autoincrement())
  cartId       Int     @map("cart_id")
  productId    String  @map("product_id")
  productCount Int     @default(1) @map("product_count")
  cart         Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [productId])

  @@map("cart_items")
}

model Cart {
  id        Int        @id @default(autoincrement())
  number    String     @unique
  count     Int        @default(0)
  summ      Float      @default(0)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  items     CartItem[]
  user      User       @relation(fields: [number], references: [number], onDelete: Cascade)

  @@map("carts")
}

model Order {
  id            Int           @id @default(autoincrement())
  orderId       String        @unique @default(uuid()) @map("order_id")
  userId        Int           @map("user_id")
  userNumber    String        @map("number")
  fullName      String        @map("full_name")
  contactNumber String        @map("contact_number")
  productItems  Json          @map("product_items")
  count         Int
  summ          Float
  address       String
  comment       String?       // Mijoz izohi (ixtiyoriy)
  courierUserId Int?          @map("courier_user_id")
  deliverySumm  Float         @default(0) @map("delivery_summ")
  paymentType   PaymentType   @map("payment_type")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  orderStatus   OrderStatus   @default(NEW) @map("order_status")
  grade         Int?          
  createdAt     DateTime      @default(now()) @map("created_at")
  user          User          @relation(fields: [userNumber], references: [number])

  @@map("orders")
}

enum Role {
  USER
  ADMIN
  COURIER
}

enum UserStatus {
  ACTIVE
  NOCASH
  BANNED
}

enum Lang {
  UZ
  RU
  EN
}

enum PaymentType {
  CLICK
  PAYME
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
}

enum OrderStatus {
  NEW
  ACCEPTED
  ON_THE_WAY
  DELIVERED
  CANCELLED
}

model Settings {
  id                 Int      @id @default(1)
  deliverySumm       Float    @default(30000) @map("delivery_summ")
  maintenanceMode    Boolean  @default(false) @map("maintenance_mode")
  maintenanceMessage String?  @map("maintenance_message")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// Nuvita AI Chat System
model ChatSession {
  id        Int           @id @default(autoincrement())
  sessionId String        @unique @default(uuid()) @map("session_id")
  userId    Int?          @map("user_id")
  number    String?       // Guest user phone or identifier
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  messages  ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        Int         @id @default(autoincrement())
  sessionId Int         @map("session_id")
  role      MessageRole // USER or ASSISTANT
  content   String
  createdAt DateTime    @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

enum MessageRole {
  USER
  ASSISTANT
}

model Banner {
  id        Int      @id @default(autoincrement())
  image     String   // Banner rasm yo'li
  link      String   @default("https://nuvita.uz/") // Bosilganda o'tiladigan havola
  order     Int      @default(0) // Ko'rsatish tartibi
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("banners")
}

model SavedProduct {
  id        Int      @id @default(autoincrement())
  number    String   // User phone number
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [number], references: [number], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [productId], onDelete: Cascade)

  @@unique([number, productId])
  @@map("saved_products")
}
